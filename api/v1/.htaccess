########################################
# API Rewrite Rules
########################################
<IfModule mod_rewrite.c>
	Options +FollowSymLinks
	########################################
	# Try to fix conflicting rewrite rules 
	# set by Wordpress etc:
	########################################
	RewriteEngine Off
	RewriteEngine On
	########################################
	# Set Rewrite Base
	########################################
	#RewriteBase /api/v1
	########################################
	# Always remove trailing slash
	########################################
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_URI} (.+)/$
	RewriteRule ^ %1 [L,R]
	########################################
	# Statistics Rewrites
	########################################
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^(statistics)/(entity)/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)? index.php?action=$1&itemType=$2&entityType=$3&entityID=$4 [QSA,L]
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^(statistics)/(entity)/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)? index.php?action=$1&itemType=$2&entityType=$3 [QSA,L]
	########################################
	# IIIF / Transcript Rewrites
	########################################
	# WebVTT transcript download for a media item
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^media/([a-zA-Z0-9_-]+)/transcript\.vtt$ index.php?action=transcript&itemType=vtt&id=$1 [QSA,L]
	# IIIF Collection for a parliament instance
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^iiif/collection/([a-zA-Z0-9_-]+)/?$ index.php?action=iiif&itemType=collection&parliament=$1 [QSA,L]
	# IIIF Collection for an electoral period within a parliament
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^iiif/collection/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)/?$ index.php?action=iiif&itemType=collection&parliament=$1&electoralPeriod=$2 [QSA,L]
	########################################
	# Generic URL Rewrites
	########################################
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^(search|autocomplete|statistics|user|index|status|lang|import|externalData|alert|notification|systemMessage)/([a-zA-Z0-9_-]+)? index.php?action=$1&itemType=$2 [QSA,L]
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^(status)/? index.php?action=$1&itemType=all [QSA,L]
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)? index.php?action=getItem&itemType=$1&id=$2 [QSA,L]
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^([a-zA-Z0-9_-]+)? index.php?action=$1 [QSA]
</IfModule>